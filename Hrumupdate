<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HRUM — Backtest Metode Kang Yayan v3 | 9 Mei 2026</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Bebas+Neue&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg:      #060a0f;
  --bg2:     #0a1118;
  --bg3:     #0e1825;
  --border:  #1a2535;
  --border2: #243347;
  --text:    #d4e0ef;
  --muted:   #4a6080;
  --muted2:  #7a96b5;
  --accent:  #38bdf8;
  --green:   #34d399;
  --green2:  #10b981;
  --red:     #f87171;
  --red2:    #ef4444;
  --orange:  #fb923c;
  --yellow:  #fbbf24;
  --purple:  #a78bfa;
  --cyan:    #22d3ee;
  --alert:   #ff4444;
  --alert-bg:#1a0808;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Syne', sans-serif;
  font-size: 14px;
  line-height: 1.6;
  min-height: 100vh;
}

/* ── ALERT BANNER ── */
.alert-banner {
  background: var(--alert-bg);
  border-bottom: 2px solid var(--alert);
  padding: 10px 24px;
  display: flex;
  align-items: center;
  gap: 12px;
  animation: pulse-alert 2s infinite;
}
@keyframes pulse-alert {
  0%,100% { border-color: #ff4444; }
  50% { border-color: #ff8888; }
}
.alert-icon { font-size: 20px; }
.alert-text { font-family: 'Space Mono', monospace; font-size: 12px; color: #ff8888; }
.alert-text strong { color: #ff4444; font-size: 13px; }

/* ── HEADER ── */
.header {
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  padding: 20px 24px 16px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}
.ticker-block { display: flex; align-items: center; gap: 16px; }
.ticker {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 42px;
  color: var(--accent);
  letter-spacing: 2px;
  line-height: 1;
}
.ticker-sub { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--muted2); line-height: 1.7; }
.price-block { text-align: right; }
.price-main {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 38px;
  color: var(--red);
  line-height: 1;
}
.price-change {
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  color: var(--red2);
  font-weight: 700;
}
.price-meta { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--muted2); margin-top: 2px; }
.badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 4px;
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1px;
}
.badge-warning { background: #2a1500; color: var(--orange); border: 1px solid #4a2800; }
.badge-danger  { background: var(--alert-bg); color: var(--alert); border: 1px solid #3a0000; }
.badge-ok      { background: #001a0d; color: var(--green); border: 1px solid #003320; }
.badge-neutral { background: #131d2a; color: var(--muted2); border: 1px solid var(--border2); }

/* ── TABS ── */
.tabs {
  display: flex;
  gap: 2px;
  margin-top: 14px;
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  scrollbar-width: none;
}
.tabs::-webkit-scrollbar { display: none; }
.tab {
  padding: 8px 16px;
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--muted2);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  transition: all 0.2s;
  background: none;
  border-top: none;
  border-left: none;
  border-right: none;
}
.tab:hover { color: var(--text); }
.tab.active { color: var(--accent); border-bottom-color: var(--accent); }

/* ── MAIN ── */
.main { padding: 20px 24px; max-width: 1000px; margin: 0 auto; }
.panel { display: none; }
.panel.active { display: block; }

/* ── CARDS ── */
.card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 16px;
}
.card-title {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--muted2);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.card-title::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

/* ── GRID ── */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
.grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
@media(max-width:600px) {
  .grid-4 { grid-template-columns: repeat(2,1fr); }
  .grid-3 { grid-template-columns: 1fr 1fr; }
  .grid-2 { grid-template-columns: 1fr; }
}

/* ── KPI CARDS ── */
.kpi {
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: 6px;
  padding: 12px 14px;
}
.kpi-label { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--muted); letter-spacing: 0.5px; margin-bottom: 4px; }
.kpi-value { font-family: 'Bebas Neue', sans-serif; font-size: 22px; line-height: 1; color: var(--text); }
.kpi-sub { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--muted2); margin-top: 2px; }

/* ── CHART CONTAINER ── */
.chart-wrap { position: relative; height: 240px; }
.chart-wrap-tall { position: relative; height: 300px; }

/* ── TABLE ── */
.tbl { width: 100%; border-collapse: collapse; font-family: 'Space Mono', monospace; font-size: 11px; }
.tbl th { color: var(--muted2); text-transform: uppercase; letter-spacing: 0.5px; font-size: 10px; padding: 6px 10px; border-bottom: 1px solid var(--border); text-align: left; font-weight: 400; }
.tbl td { padding: 7px 10px; border-bottom: 1px solid var(--border); vertical-align: middle; }
.tbl tr:last-child td { border-bottom: none; }
.tbl tr:hover td { background: var(--bg3); }
.tbl .num { text-align: right; font-variant-numeric: tabular-nums; }

/* ── BROKER ROWS ── */
.br-buy  td { color: var(--green); }
.br-sell td { color: var(--red2); }
.br-neutral td { color: var(--muted2); }

/* ── SCORECARD ── */
.score-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.score-name { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--text); width: 130px; flex-shrink: 0; }
.score-bar-wrap { flex: 1; height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }
.score-bar { height: 100%; border-radius: 4px; transition: width 0.8s ease; }
.score-num { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--muted2); width: 36px; text-align: right; flex-shrink: 0; }
.score-total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid var(--border);
  padding-top: 10px;
  margin-top: 4px;
}
.score-total-label { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--muted2); }
.score-total-val { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--yellow); }

/* ── WYCKOFF PHASE ── */
.wyckoff-strip {
  display: flex;
  gap: 4px;
  margin-bottom: 12px;
  overflow-x: auto;
}
.wy-phase {
  flex: 1;
  min-width: 60px;
  padding: 8px 6px;
  border-radius: 5px;
  text-align: center;
  border: 1px solid transparent;
  font-family: 'Space Mono', monospace;
  font-size: 10px;
}
.wy-phase.past   { background: #0e1825; color: var(--muted); border-color: var(--border); }
.wy-phase.active { background: #1a2a0a; color: #86efac; border-color: #365314; }
.wy-phase.risk   { background: #1a0808; color: #fca5a5; border-color: #7f1d1d; }
.wy-phase-label  { font-size: 9px; opacity: 0.7; margin-top: 2px; }

/* ── RISK ── */
.risk-item {
  border-left: 3px solid;
  padding: 10px 12px;
  margin-bottom: 8px;
  background: var(--bg3);
  border-radius: 0 4px 4px 0;
}
.risk-title { font-weight: 700; font-size: 12px; margin-bottom: 4px; }
.risk-desc  { font-size: 12px; color: var(--muted2); line-height: 1.5; }

/* ── TRADE PLAN ── */
.tp-row {
  display: flex;
  align-items: stretch;
  gap: 0;
  margin-bottom: 4px;
}
.tp-tag {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1px;
  padding: 8px 12px;
  width: 90px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  border-radius: 4px 0 0 4px;
}
.tp-content {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-left: none;
  border-radius: 0 4px 4px 0;
  padding: 8px 12px;
  flex: 1;
  font-family: 'Space Mono', monospace;
  font-size: 11px;
}
.tp-price { font-size: 14px; font-weight: 700; color: var(--text); }
.tp-note  { font-size: 10px; color: var(--muted2); margin-top: 2px; }

/* ── SIGNAL TIMELINE ── */
.sig-item {
  display: flex;
  gap: 12px;
  margin-bottom: 12px;
  position: relative;
}
.sig-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4px;
  position: relative;
  z-index: 1;
}
.sig-dot::after {
  content: '';
  position: absolute;
  left: 4px; top: 10px;
  width: 2px;
  height: calc(100% + 10px);
  background: var(--border);
}
.sig-item:last-child .sig-dot::after { display: none; }
.sig-body { flex: 1; }
.sig-period { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--muted); }
.sig-action { font-family: 'Bebas Neue', sans-serif; font-size: 18px; line-height: 1; margin: 2px 0; }
.sig-price  { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--text); }
.sig-reason { font-size: 12px; color: var(--muted2); }
.sig-result {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  font-weight: 700;
  margin-top: 4px;
}

/* ── CHECKLIST ── */
.chk-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
  font-size: 12px;
}
.chk-item:last-child { border-bottom: none; }
.chk-icon { font-size: 14px; flex-shrink: 0; margin-top: 1px; }
.chk-label { flex: 1; color: var(--text); }
.chk-status { font-family: 'Space Mono', monospace; font-size: 10px; flex-shrink: 0; }

/* ── INFO BOX ── */
.infobox {
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: 6px;
  padding: 12px 14px;
  font-size: 12px;
  color: var(--muted2);
  line-height: 1.6;
  margin-bottom: 12px;
}
.infobox strong { color: var(--text); }

/* ── SCENARIO ── */
.scenario-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }
@media(max-width:500px){ .scenario-grid { grid-template-columns: 1fr; } }
.scenario-card {
  border: 1px solid;
  border-radius: 6px;
  padding: 12px;
  text-align: center;
}
.s-icon  { font-size: 24px; margin-bottom: 6px; }
.s-label { font-family: 'Space Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; opacity: 0.7; }
.s-price { font-family: 'Bebas Neue', sans-serif; font-size: 28px; line-height: 1; margin: 4px 0; }
.s-prob  { font-family: 'Space Mono', monospace; font-size: 11px; opacity: 0.8; }
.s-basis { font-size: 11px; opacity: 0.65; margin-top: 4px; line-height: 1.4; }

/* ── FOOTER ── */
.footer {
  text-align: center;
  padding: 20px 24px;
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  border-top: 1px solid var(--border);
  line-height: 1.8;
}
.divider { height: 1px; background: var(--border); margin: 12px 0; }
</style>
</head>
